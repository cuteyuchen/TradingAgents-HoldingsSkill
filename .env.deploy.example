ADVISOR_TOKEN=adv_replace_me_with_a_real_token
APP_SECRET_KEY=replace_with_a_stable_random_secret_at_least_32_bytes
ALLOW_REGISTRATION=true

# GHCR image settings.
GHCR_OWNER=cuteyuchen
IMAGE_TAG=latest

# Both ports reach the same application container. BACKEND_PORT keeps legacy
# /api/v1 integrations working; FRONTEND_PORT is the primary browser address.
BACKEND_PORT=18000
FRONTEND_PORT=18080
PUBLIC_APP_URL=http://192.168.1.13:18080

ADVISOR_CORS_ORIGINS=http://192.168.1.13:18080,http://192.168.1.13:18000,http://localhost:18080,http://localhost:18000
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
ANALYSIS_HISTORY_LIMIT=5
MAX_UPLOAD_BYTES=12582912
