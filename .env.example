# Legacy V1 archive token. Keep this while the existing skill still uploads to
# /api/v1/archives. Generate with: cd backend && python -m app.seed
ADVISOR_TOKEN=adv_replace_me_with_a_real_token

# V2 identity, JWT signing, API-key encryption, and webhook encryption.
# Generate a stable random secret of at least 32 bytes and never change it after
# storing model keys or notification webhooks.
APP_SECRET_KEY=replace_with_a_stable_random_secret_at_least_32_bytes
ALLOW_REGISTRATION=true
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# Application and automatic analysis.
PUBLIC_APP_URL=http://localhost:8080
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=60
ANALYSIS_HISTORY_LIMIT=5
MAX_UPLOAD_BYTES=12582912

# Optional overrides (defaults shown)
# BACKEND_PORT=8000
# FRONTEND_PORT=8080
# ADVISOR_DB_PATH=/app/data/advisor.db
# ADVISOR_ARTIFACTS_DIR=/app/data/artifacts
# ADVISOR_SQLITE_JOURNAL_MODE=WAL
# ADVISOR_CORS_ORIGINS=http://localhost:8080,http://localhost:5173
