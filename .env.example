# Legacy V1 archive token. Keep this while the existing skill and archive UI
# still use /api/v1. Generate with: cd backend && python -m app.seed
ADVISOR_TOKEN=adv_replace_me_with_a_real_token

# V2 identity and secret encryption. Use a stable random value of at least
# 32 bytes in production. Changing it invalidates JWTs and encrypted API keys.
APP_SECRET_KEY=replace_with_a_stable_random_secret_at_least_32_bytes
ALLOW_REGISTRATION=true
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=30

# Optional overrides (defaults shown)
# ADVISOR_PORT=8000
# ADVISOR_DB_PATH=/app/data/advisor.db
# ADVISOR_ARTIFACTS_DIR=/app/data/artifacts
# ADVISOR_SQLITE_JOURNAL_MODE=WAL
# ADVISOR_CORS_ORIGINS=http://localhost:8080,http://localhost:5173
